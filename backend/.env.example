# Free LLM access via Groq: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase project (Project Settings -> API). The service role key is secret -
# keep it on the server only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Ollama-cloud fallback (OpenAI-compatible). Used when Groq returns 429/5xx.
FALLBACK_BASE_URL=https://api.ollama.ai/v1
FALLBACK_API_KEY=your-ollama-api-key
FALLBACK_MODEL=llama3.3:70b

# Comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173

# Second LLM pass that reviews/corrects the draft evaluation before it's
# persisted. Safe to disable (falls back to the single-pass score) if it
# adds unwanted latency or cost.
EVAL_SELF_CRITIQUE_ENABLED=true
